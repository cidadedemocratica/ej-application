{% extends 'base.jinja2' %}
{% block metaOG2 %}

    <meta name="description" property="og:title" content="Area de integração da EJ com outras ferramentas.">
    <meta property="og:description" content="Area de integração da EJ com outras ferramentas.">

{% endblock metaOG2 %}
{% block _menu %} {{ menu(request.user, board_palette) }} {% endblock %}

{% block content %}
<div class="tools">
<div class="tools-title">
	<h1>{{_("Tools")}} > {{ tool["integration"] }}</h1>
<span>{{tool["description"] }}</span>
</div>
	<div>
		<p>
			{{_('With this feature you can collect opinions from your audience without') }}
			{{_('using EJ interface directly. This component can be included in your') }}
			{{_('site\'s html, and it will allow users to participate on conversations') }}
			{{_('and add comments from within your personal site.') }}
		</p>
		<p>
			{{_('To add this conversation to your site/platform, first select some settings and then copy the code below:') }}
			<h2>{{_("Settings")}}</h2>
			
			<form method="POST">
				{{ csrf_input }}
				{% block form_content %}
				{{form}}				
                 <input class="is-primary" type="submit" value="{{_('Generate Script')}}">
				{% endblock %}
			</form>

			<div class="tools-section-2-snippet">
				<div id="copy-header">
					<code>&lt;script src='https://unpkg.com/ej-conversations@{{npm_version.latest}}/dist/conversations.js'&gt&lt;/script&gt</code>
					<br>
					<code>&lt;link href='https://fonts.googleapis.com/css?family=Raleway&display=swap' rel="stylesheet"&gt&lt;/link&gt</code>
					<br>
					<code>&lt;link href='{{schema}}://{{request.META['HTTP_HOST']}}/static/css/fontawesome-all.min.css' rel="stylesheet"&gt&lt;/link&gt</code>
				</div>
				<code><p>&lt;style&gt;</p>

<p> /* https://github.com/ionic-team/stencil/issues/2072 */</p>

<p>@font-face {</p>

<p> font-family: Folio;</p>

<p> font-style: normal;</p>

<p> font-weight: 400;</p>

<p> font-display: auto;</p>

<p> src: url(https://unpkg.com/ej-conversations@1.7.15/dist/conversations/assets/fonts/folio_bold_condensed.ttf);</p>

<p>}</p>

<p>@font-face {</p>

<p> font-family: Helvetica;</p>

<p> font-style: normal;</p>

<p> font-weight: 400;</p>

<p> font-display: auto;</p>

<p> src: url('https://unpkg.com/ej-conversations@1.7.15/dist/conversations/assets/fonts/helvetica_neue_lts_roman.otf');</p>

<p>}</p>

<p>@font-face {</p>

<p> font-family: 'Font Awesome 5 Free';</p>

<p> font-style: normal;</p>

<p> font-weight: 400;</p>

<p> font-display: auto;</p>

<p> src: url('https://unpkg.com/ej-conversations@1.7.15/dist/conversations/assets/fonts/fa-regular-400.ttf');</p>

<p>}</p>

<p>@font-face {</p>

<p> font-family: 'Font Awesome 5 Free';</p>

<p> font-style: normal;</p>

<p> font-weight: 400;</p>

<p> font-display: auto;</p>

<p> src: url('https://unpkg.com/ej-conversations@1.7.15/dist/conversations/assets/fonts/fa-brands-400.ttf');</p>

<p>}</p>

<p>@font-face {</p>

<p> font-family: 'Font Awesome 5 Free';</p>

<p> font-style: normal;</p>

<p> font-weight: 400;</p>

<p> font-display: auto;</p>

<p> src: url('https://unpkg.com/ej-conversations@1.7.15/dist/conversations/assets/fonts/fa-solid-900.ttf');</p>

<p>}</p>

<p>&lt;/style&gt;</p></code>
				<button onclick="copySnippet('copy-header');">{{_('Copy Script')}}</button>
			</div>

			{{_('and this snippet of code on the page body:') }}

			<div class="tools-section-2-snippet">
				<div>
					<code>&lt;ej-conversation host={{schema}}://{{request.META['HTTP_HOST']}}
					cid="{{conversation.id}}" {{component_props}}&gt&lt;/ej-conversation&gt</code>
				</div>
				<div>
					<button onclick="copySnippet('copy-body');">
						{{_('Copy Script')}}</button>
				</div>
			</div>
		</p>
</div>
<p><a href="{{ conversation.url('conversation_tools:index') }}" title="{{ _('Back to tools') }}"
		class="lowercase bold text-brand">
	<i class="fa fa-chevron-left"></i>{% trans %}Back to tools{% endtrans %}
</a></p>
</div>
   <script>
	   function showContent2() {
		   let content = document.querySelector(".tools-content-2");
		   let section = document.querySelector(".tools-section-2");
		   if (window.getComputedStyle(content).maxHeight == "0px") {
			content.style.maxHeight = "400px";
			section.style.borderRadius = "unset";
			section.style.borderStyle = "unset";
		   }
		   else {
			content.style.maxHeight = "0px";
			section.style.borderStyle = "solid";
			section.style.borderRadius = "1rem";
		   }
	   }

	   function copySnippet(elementId){
		   	var copyText = document.getElementById(elementId);
			copyText.select();
			copyText.setSelectionRange(0, 99999)
			document.execCommand("copy");
	   }
   </script>
{% endblock %}
